# ==========================================
# Dependencies (Frontend & Backend)
# ==========================================
node_modules/
.pnp/
.pnp.*

# ==========================================
# Environment Variables (Keep these secret!)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==========================================
# Build & Production Outputs
# ==========================================
# React / Frontend builds (Vite, CRA, Next.js)
/frontend/build/
/frontend/dist/
/frontend/.next/
/frontend/out/

# Backend builds (if using TypeScript or bundlers)
/backend/build/
/backend/dist/

# Generic build folders (just in case)
build/
dist/

# ==========================================
# Logs & Databases
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local SQLite databases (if used in backend)
*.sqlite
*.sqlite3
*.db

# ==========================================
# Testing & Caching
# ==========================================
coverage/
.eslintcache
.stylelintcache

# ==========================================
# File Uploads / Temp directories (Backend)
# ==========================================
/backend/uploads/
/backend/temp/
/backend/tmp/

# ==========================================
# OS & Editor Files
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs (VS Code, JetBrains, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?